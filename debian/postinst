#!/bin/bash
set -e

# Atualiza cache de ícones do desktop
if [ -x /usr/bin/update-desktop-database ]; then
    update-desktop-database -q /usr/share/applications || true
fi

# Atualiza cache de ícones GTK
if [ -x /usr/bin/gtk-update-icon-cache ]; then
    gtk-update-icon-cache -q /usr/share/icons/hicolor || true
fi

echo "Disk Overview instalado com sucesso!"
echo "Execute 'disk-overview' ou encontre no menu de aplicativos."

#DEBHELPER#

exit 0
